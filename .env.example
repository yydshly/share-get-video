# ----------------------------
# Video Lab runtime paths
# ----------------------------
# Runtime directory mounted by FastAPI for generated assets.
# Default: runtime
VIDEO_LAB_RUNTIME_DIR=runtime

# Experiment output directory.
# Default: runtime/video_lab/experiments
VIDEO_LAB_EXPERIMENTS_DIR=runtime/video_lab/experiments

# Public URL prefix for runtime assets.
# Default: /runtime
PUBLIC_RUNTIME_URL_PREFIX=/runtime

# ----------------------------
# External binaries
# ----------------------------
# Optional explicit ffmpeg path. Leave empty to use PATH.
FFMPEG_BINARY=
# Optional explicit ffprobe path. Leave empty to use PATH.
FFPROBE_BINARY=

# ----------------------------
# MiniMax TTS API Configuration
# ----------------------------
# Required for tts_subtitle_compose route.
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE_ID=male-qn-qingse
MINIMAX_TTS_SPEED=1.0
MINIMAX_TTS_VOLUME=1.0
MINIMAX_TTS_BASE_URL=https://api.minimaxi.com
