# Video Lab backend API endpoint
VITE_API_BASE=http://localhost:8000/video-lab

# Runtime asset base URL.
# Usually same backend origin without /video-lab.
VITE_RUNTIME_BASE=http://localhost:8000

# URL prefix for runtime assets. Must match PUBLIC_RUNTIME_URL_PREFIX on backend.
# Default: /runtime
VITE_RUNTIME_URL_PREFIX=/runtime
